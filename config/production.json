{
  "app": {
    "port": "${PORT:3000}",
    "host": "0.0.0.0"
  },
  "llm": {
    "provider": "${LLM_PROVIDER:ollama}",
    "endpoints": {
      "ollama": "${OLLAMA_ENDPOINT:http://localhost:11434}",
      "openai": "${OPENAI_ENDPOINT:https://api.openai.com/v1}",
      "azure": "${AZURE_ENDPOINT:}"
    },
    "apiKey": "${LLM_API_KEY:}",
    "timeout": 60000
  },
  "knowledge": {
    "basePath": "${KNOWLEDGE_PATH:./knowledge}"
  },
  "session": {
    "storage": "${SESSION_STORAGE:file}",
    "dataPath": "${SESSION_DATA_PATH:./data/sessions}",
    "maxSessions": "${MAX_SESSIONS:1000}"
  },
  "security": {
    "cors": {
      "origin": "${CORS_ORIGINS:https://yourdomain.com}".split(",")
    },
    "rateLimit": {
      "general": {
        "max": "${RATE_LIMIT_GENERAL:100}"
      },
      "api": {
        "max": "${RATE_LIMIT_API:50}"
      }
    },
    "requestSizeLimit": "${REQUEST_SIZE_LIMIT:10mb}"
  },
  "logging": {
    "level": "${LOG_LEVEL:warn}",
    "file": {
      "enabled": true,
      "path": "${LOG_PATH:./logs}",
      "maxSize": "${LOG_MAX_SIZE:100MB}",
      "maxFiles": "${LOG_MAX_FILES:10}"
    },
    "console": {
      "enabled": false
    }
  },
  "monitoring": {
    "enabled": "${MONITORING_ENABLED:true}"
  }
}